# ─────────────────────────────────────────────
# Flask Backend  (backend/.env)
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Resend Email Service (https://resend.com/api-keys)
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=AI Interviewer <onboarding@resend.dev>
REPLY_TO_EMAIL=your_email@gmail.com

# ─────────────────────────────────────────────
# Node Signaling Server  (server/.env)
# ─────────────────────────────────────────────
PORT=3000
CLIENT_ORIGIN=https://interviewer-ai-i14a.onrender.com

# Firebase Admin SDK — path to service account JSON
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Metered.ca Dynamic TURN Credentials
# Get these from: https://dashboard.metered.ca/turn-servers
METERED_API_KEY=your_metered_api_key_here
TURN_USERNAME=your_turn_username_here
TURN_CREDENTIAL=your_turn_credential_here

# Demo HR custom token authentication
# Used by the frontend to obtain a Firebase ID token for the mock HR user
DEMO_HR_UID=hr-admin-001
DEMO_HR_SECRET=your_demo_hr_secret_here

# ─────────────────────────────────────────────
# React Frontend  (frontend/.env)
# ─────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id
VITE_BACKEND_URL=http://localhost:5000
VITE_SIGNALING_URL=http://localhost:3000

# Shared secret for demo HR socket authentication (must match DEMO_HR_SECRET on server)
VITE_DEMO_HR_SECRET=your_demo_hr_secret_here
